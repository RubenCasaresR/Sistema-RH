# ============================================================
# SISTEMA RH - Seguridad y reescritura
# ============================================================

# Codificación por defecto
AddDefaultCharset UTF-8

# Denegar listado de directorios
Options -Indexes

# Proteger archivo .htaccess
<FilesMatch "^\.ht">
    Require all denied
</FilesMatch>

# Redirigir todo al index.php (single entry point)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Denegar acceso directo a directorios sensibles
    RewriteRule ^config/.*$ - [F,L]
    RewriteRule ^includes/.*$ - [F,L]
    RewriteRule ^sql/.*$ - [F,L]

    # Si el archivo o directorio existe, servirlo directamente
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
</IfModule>

# Prevenir clickjacking
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# Cache estático para assets
<FilesMatch "\.(css|js|jpg|jpeg|png|gif|ico|svg|woff2?)$">
    Header set Cache-Control "max-age=2592000, public"
</FilesMatch>
